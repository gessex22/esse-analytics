# ─── Servidor ──────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:4000

# ─── Base de datos ─────────────────────────────────────────────────
# Local (recomendado para self-hosted):
MONGO_URI=mongodb://localhost:27017/renders_manager
# Atlas (nube):
# MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/renders_manager

# ─── YouTube (console.cloud.google.com) ────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:4000/api/youtube/auth/callback

# ─── Instagram / Meta (developers.facebook.com) ────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4000/api/instagram/auth/callback
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ─── TikTok (developers.tiktok.com) ────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4000/api/tiktok/auth/callback
